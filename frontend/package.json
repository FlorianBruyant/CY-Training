{
    "name": "cy-training-frontend",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "20.19.0 || >=22.12.0"
    },
    "scripts": {
        "build-only": "vite build",
        "build": "npm run test && npm run build-only",
        "dev": "vite",
        "format": "prettier --write --experimental-cli src/",
        "host": "vite dev --host",
        "lint:fix": "eslint --cache --fix",
        "lint": "eslint --cache",
        "preview": "vite preview",
        "test:unit": "vitest",
        "test": "npm run lint && npm run type-check",
        "type-check": "vue-tsc --build"
    },
    "dependencies": {
        "@tsconfig/node24": "24.0.4",
        "@types/jsdom": "27.0.0",
        "@types/node": "25.2.3",
        "@vitejs/plugin-vue": "6.0.4",
        "@vitejs/plugin-vue-jsx": "5.1.4",
        "@vue/tsconfig": "0.8.1",
        "@vueuse/core": "14.2.1",
        "bcryptjs": "3.0.3",
        "dompurify": "3.3.1",
        "pinia": "3.0.4",
        "sass": "1.97.3",
        "vite": "7.3.1",
        "vite-plugin-vue-devtools": "8.0.6",
        "vue": "3.5.28",
        "vue-i18n": "11.2.8",
        "vue-router": "5.0.2",
        "vue-tsc": "3.2.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/dompurify": "3.0.5",
        "@vue/test-utils": "2.4.6",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-vue": "10.8.0",
        "globals": "17.3.0",
        "jsdom": "28.1.0",
        "prettier": "3.8.1",
        "typescript": "5.9.3",
        "typescript-eslint": "8.56.0",
        "vite": "7.3.1",
        "vitest": "4.0.18"
    }
}
